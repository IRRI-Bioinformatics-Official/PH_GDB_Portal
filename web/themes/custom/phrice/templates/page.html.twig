<!DOCTYPE html>
<html{{ html_attributes }}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ head_title|safe_join(' | ') }}</title>
  {{ head }}
  {{ styles }}
</head>
<body{{ attributes }}>
  {{ page_top }}
  <header class="site-header">
    <div class="site-branding">
      <div class="logo">UP</div>
      <div class="site-name">
        <a href="{{ base_path }}">1001 PH Rice Genome Portal</a>
      </div>
    </div>
    <nav class="main-nav">
      <a href="{{ base_path }}">Home</a>
      <div class="nav-dropdown">
        <a href="{{ base_path }}data" class="nav-dropdown-toggle">Data ▾</a>
        <div class="nav-dropdown-menu">
          <a href="{{ base_path }}data/genotype-viewer">Genotype Viewer</a>
          <a href="{{ base_path }}data/jbrowse">JBrowse</a>
          <a href="{{ base_path }}data/jbrowse2">JBrowse2</a>
        </div>
      </div>
      <a href="{{ base_path }}tools">Tools</a>
      <a href="{{ base_path }}publications">Publications</a>
      <a href="{{ base_path }}about">About</a>
    </nav>
  </header>
  <main>{{ page.content }}</main>
  <footer class="site-footer">
    <div class="footer-left">
      © {{ "now"|date("Y") }} <strong>1001 Philippine Rice Genome Portal</strong> — University of the Philippines System<br>
      <small>In partnership with IRRI &amp; DA-PhilRice</small>
    </div>
    <div class="footer-right">
      <a href="{{ base_path }}privacy">Privacy</a>
      <a href="{{ base_path }}terms">Terms</a>
      <a href="{{ base_path }}contact">Contact</a>
      <a href="{{ base_path }}api">API</a>
      {% if not logged_in %}
        <a href="{{ base_path }}user/login">Login</a>
      {% else %}
        <a href="{{ base_path }}user">My Account</a>
        <a href="{{ base_path }}user/logout">Logout</a>
      {% endif %}
    </div>
  </footer>
  {{ page_bottom }}
  {{ scripts }}
</body>
</html>
