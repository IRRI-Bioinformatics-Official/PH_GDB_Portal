<!DOCTYPE html>
<html{{ html_attributes }}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ head_title|safe_join(' | ') }}</title>
  {{ head }}
  {{ styles }}
</head>
<body{{ attributes }}>
  {{ page_top }}
  <header class="site-header">
    <div class="site-branding">
      <div class="logo">UP</div>
      <div class="site-name">
        <a href="{{ path('<front>') }}">1001 PH Rice Genome Portal</a>
      </div>
    </div>
    <nav class="main-nav">
      <a href="{{ path('<front>') }}">Home</a>
      <a href="/ph_gdb/data">Data</a>
      <a href="/ph_gdb/tools">Tools</a>
      <a href="/ph_gdb/publications">Publications</a>
      <a href="/ph_gdb/about">About</a>
    </nav>
  </header>
  <main>{{ page.content }}</main>
  <footer class="site-footer">
    <div class="footer-left">
      © {{ "now"|date("Y") }} <strong>1001 Philippine Rice Genome Portal</strong> — University of the Philippines System<br>
      <small>In partnership with IRRI &amp; DA-PhilRice</small>
    </div>
    <div class="footer-right">
      <a href="/ph_gdb/privacy">Privacy</a>
      <a href="/ph_gdb/terms">Terms</a>
      <a href="/ph_gdb/contact">Contact</a>
      <a href="/ph_gdb/api">API</a>
    </div>
  </footer>
  {{ page_bottom }}
  {{ scripts }}
</body>
</html>
