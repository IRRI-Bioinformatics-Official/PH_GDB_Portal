<!DOCTYPE html>
<html{{ html_attributes }}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ head_title|safe_join(' | ') }}</title>
  {{ head }}
  {{ styles }}
</head>
<body{{ attributes }}>
  {{ page_top }}
  <header class="site-header">
    <div class="site-branding">
      <div class="logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a6b3a" stroke-width="2.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
      </div>
      <div class="site-name">
        <a href="{{ path('<front>') }}">1001 PH Rice Genome Portal</a>
      </div>
    </div>
    <nav class="main-nav">
      <a href="{{ path('<front>') }}">Home</a>
      <a href="/data">Data</a>
      <a href="/tools">Tools</a>
      <a href="/publications">Publications</a>
      <a href="/about">About</a>
    </nav>
  </header>
  <main>{{ page.content }}</main>
  <footer class="site-footer">
    <div class="footer-left">
      © {{ "now"|date("Y") }} <strong>1001 Philippine Rice Genome Portal</strong> — IRRI &amp; DA-PhilRice
    </div>
    <div class="footer-right">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/contact">Contact</a>
      <a href="/api">API</a>
    </div>
  </footer>
  {{ page_bottom }}
  {{ scripts }}
</body>
</html>
